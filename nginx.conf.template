server {
    listen 0.0.0.0:${PORT};
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # SPA routing (solo ${PORT} se sustituye por envsubst; $uri queda para nginx)
    location / {
        try_files $uri $uri/ /index.html;
    }

    # API proxy intentionally omitted for cloud deploys.
    # Frontend must call backend using VITE_API_URL.

    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;
}
